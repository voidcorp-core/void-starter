{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    "packages/config": {
      "project": ["*.ts"],
      "ignoreDependencies": ["next"]
    },
    "packages/*": {
      "project": "src/**/*.ts"
    },
    "packages/core": {
      "ignoreDependencies": ["pino-pretty"]
    },
    "packages/ui": {
      "project": "src/**/*.{ts,tsx}"
    },
    "apps/*": {
      "entry": ["src/app/**/page.tsx", "src/app/**/layout.tsx", "tests/e2e/**/*.spec.ts"],
      "project": "src/**/*.{ts,tsx}",
      "ignore": ["src/components/_examples/**"],
      "ignoreDependencies": ["drizzle-orm", "@testing-library/react", "@testing-library/user-event"]
    }
  }
}
