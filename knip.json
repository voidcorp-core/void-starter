{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    "packages/config": {
      "project": ["*.ts"]
    },
    "packages/*": {
      "project": "src/**/*.ts"
    },
    "packages/core": {
      "ignoreDependencies": ["pino-pretty"]
    },
    "packages/auth": {
      "ignoreDependencies": [
        "@void/core",
        "@void/db",
        "better-auth",
        "@better-auth/drizzle-adapter",
        "zod"
      ]
    },
    "apps/*": {
      "entry": [
        "src/app/**/page.tsx",
        "src/app/**/layout.tsx",
        "src/app/**/route.ts",
        "src/middleware.ts",
        "src/instrumentation.ts",
        "next.config.ts"
      ],
      "project": "src/**/*.{ts,tsx}"
    }
  }
}
